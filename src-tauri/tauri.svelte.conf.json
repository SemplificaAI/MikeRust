{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MikeRust",
  "version": "0.5.4",
  "identifier": "com.mikerust.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir ./frontend dev",
    "beforeBuildCommand": "pnpm --dir ./frontend build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "MikeRust",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
