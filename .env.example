# MikeRust — environment variables

# SQLite database file path. Leave commented out to use the secure
# default: `<user-home>/mikerust-data/mike.db`. Keeping the DB out of
# the project tree avoids two problems: (a) the Tauri-dev file watcher
# rebuilding on every WAL flush, and (b) any chance of `git add .`
# sweeping the DB (which contains your saved API keys) into a commit.
# Only override if you know what you're doing (tests / CI / a sandbox).
# DATABASE_URL=sqlite:./mike.db

# Sovereign auth — generate with: openssl rand -base64 48
JWT_SECRET=your-random-secret-min-32-chars

# Storage — local filesystem (default) or S3/R2 (feature: s3-storage).
# Same reasoning as DATABASE_URL above: default is `<user-home>/
# mikerust-data/storage` (outside the project tree). Override only for
# tests / CI / sandbox runs.
# STORAGE_PATH=./data/storage
# R2_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=mike

# PDF extraction — pdfium DLL bundled in libs/pdfium/
# (no env var needed; discovered automatically next to executable)

# Local / self-hosted LLM via OpenAI-compatible endpoint (vLLM, Infomaniak, etc.)
VLLM_BASE_URL=
VLLM_API_KEY=
VLLM_MAIN_MODEL=
VLLM_LIGHT_MODEL=

# Cloud LLM providers (optional — only needed if using Claude/Gemini)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# MCP client — JSON array of server configs (optional)
# [{"name":"local-docs","url":"http://localhost:8080/mcp"}]
MCP_SERVERS=

# Server
#
# PORT — leave unset to let the OS pick a free high port (recommended:
# avoids 3001 collisions, the Tauri shell discovers the port at boot
# and forwards it to the frontend via the `api_base_url` Tauri command).
# Only set this when you're running the backend standalone (`cargo run`)
# and need the frontend in a regular browser at http://localhost:3000
# to know where to fetch — in that case pin PORT=3001 (or any free port)
# and set NEXT_PUBLIC_API_BASE_URL to match in frontend/.env.local.
# PORT=3001
RUST_LOG=mike=debug,tower_http=info
