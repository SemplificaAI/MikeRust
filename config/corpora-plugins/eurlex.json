{
    "id": "eurlex",
    "display_name": "EUR-Lex",
    "display_name_locale": {
        "it": "EUR-Lex",
        "en": "EUR-Lex"
    },
    "description": "Official portal for European Union law. CELEX-based retrieval of regulations, directives, decisions, treaties and case-law in 24 official languages.",
    "homepage": "https://eur-lex.europa.eu",
    "languages": [
        "bg", "cs", "da", "de", "el", "en", "es", "et", "fi", "fr",
        "ga", "hr", "hu", "it", "lt", "lv", "mt", "nl", "pl", "pt",
        "ro", "sk", "sl", "sv"
    ],
    "default_language": "en",
    "supports_language_fallback": true,
    "fallback_language": "en",
    "identifier_label": "CELEX",
    "identifier_example": "32016R0679",
    "enabled_by_default": false,
    "discovery": {
        "jurisdiction": "eu",
        "doc_types": ["legislation", "case_law"],
        "auth": "public",
        "search_mode": "sparql",
        "fetch_format": "html"
    },
    "strategy": {
        "kind": "builtin",
        "builtin_id": "eurlex"
    },
    "capabilities": {
        "search": true,
        "fetch": true,
        "documents": true,
        "documents_delete": true,
        "documents_resync": true,
        "embed_progress": true,
        "bulk_import": false,
        "user_config": true
    }
}
