{
    "id": "us-cfr",
    "display_name": "US / eCFR",
    "display_name_locale": {
        "it": "Stati Uniti — eCFR",
        "en": "United States — eCFR"
    },
    "description": "Code of Federal Regulations (eCFR). Fonte attiva con ricerca e fetch via adapter runtime.",
    "homepage": "https://www.ecfr.gov/",
    "languages": ["en"],
    "default_language": "en",
    "supports_language_fallback": false,
    "identifier_label": "CFR Title",
    "identifier_example": "14",
    "enabled_by_default": true,
    "discovery": {
        "jurisdiction": "us",
        "doc_types": ["legislation"],
        "auth": "public",
        "search_mode": "free-text",
        "fetch_format": "xml"
    },
    "strategy": {
        "kind": "http-fetch-per-id",
        "search_by_id": {
            "url_template": "https://www.ecfr.gov/current/title-{identifier}",
            "shape": "rest-html",
            "title_path": "title",
            "body_path": "body"
        },
        "search_by_keyword": {
            "url_template": "https://www.ecfr.gov/api/search/v1/results?query={query}&per_page={limit}&page=1",
            "url_template_year": "https://www.ecfr.gov/api/search/v1/results?query={query}&per_page={limit}&page=1&date={year}-12-31",
            "shape": "rest-json",
            "hits_path": "$.results",
            "identifier_at": "$.hierarchy.title",
            "title_at": "$.headings.section",
            "date_at": "$.starts_on"
        }
    },
    "capabilities": {
        "search": true,
        "fetch": true,
        "documents": true,
        "documents_delete": true,
        "documents_resync": true,
        "embed_progress": false,
        "bulk_import": false,
        "user_config": true
    },
    "sources": [
        {
            "id": "ecfr",
            "display_name": "eCFR",
            "available": false,
            "default_enabled": false,
            "status_label": "in arrivo"
        }
    ]
}
